# ====================================================
# RainExam 配置文件
# 将此文件复制为 .env，然后填写你的配置项
#   cp .env.example .env
# ====================================================

# ──────────────────────────────────────────────
# 必需配置
# ──────────────────────────────────────────────

# 雨课堂在线 Cookie
# 从浏览器开发者工具 → Network 标签 → 任意请求 → Request Headers → Cookie 复制完整字符串
XT_COOKIE=xxx
# ──────────────────────────────────────────────
# AI 解答配置（可选，使用 --answer 时需要）
# ──────────────────────────────────────────────

# API Key（下列二选一即可）
# AI_API_KEY=
# OPENAI_API_KEY=

# API 地址（根据你的 AI 服务商填写）
# 默认值: https://api.openai.com/v1
# 常用服务商:
#   DeepSeek:      https://api.deepseek.com/v1
#   通义千问:      https://dashscope.aliyuncs.com/compatible-mode/v1
#   硅基流动:      https://api.siliconflow.cn/v1
#   Ollama 本地:   http://localhost:11434/v1
# AI_BASE_URL=

# AI 模型名称
# 默认值: gpt-4o-mini
AI_MODEL=xxx
# ──────────────────────────────────────────────
# 输出配置
# ──────────────────────────────────────────────

# 每个文件包含的题目数（默认 50）
# PAGE_SIZE=50