# ====================================================
# RainExam 配置文件
# 将此文件复制为 .env，然后填写你的配置项
#   cp .env.example .env
# ====================================================

# ──────────────────────────────────────────────
# 必需配置
# ──────────────────────────────────────────────

# 雨课堂在线 Cookie（两种模式通用）
# 获取方式：登录 https://www.yuketang.cn → 浏览器开发者工具 → Application → Cookies
# 或通过 GUI 界面的「登录自动获取」按钮
XT_COOKIE='xt_lang=zh; x_access_token=你的access_token'

# ──────────────────────────────────────────────
# Quiz 模式配置（可选，使用 Quiz 模式时需要）
# ──────────────────────────────────────────────

# Quiz ID（从雨课堂网页 URL 中获取）
QUIZ_ID=

# 课堂 ID（可选，某些 Quiz 需要此参数）
CLASSROOM_ID=

# ──────────────────────────────────────────────
# AI 解答配置（可选，考试模式使用 --answer 时需要）
# ──────────────────────────────────────────────

# API Key（调用大模型的密钥，Token凭证）
AI_API_KEY=sk-你的api_key

# API 地址（根据你的 AI 服务商填写）
# 常用服务商:
#   DeepSeek:      https://api.deepseek.com/v1
#   通义千问:      https://dashscope.aliyuncs.com/compatible-mode/v1
#   硅基流动:      https://api.siliconflow.cn/v1
#   Ollama 本地:   http://localhost:11434/v1
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# AI 模型名称
AI_MODEL=qwen3.6-flash